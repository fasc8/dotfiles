#!/bin/bash

# Because Git submodule commands cannot operate without a work tree, they must
# be run from within $HOME (assuming this is the root of your dotfiles)
cd "$HOME"

pck_mngr=""
if command -v apt >/dev/null 2>&1; then
    pck_mngr="apt"
elif command -v pacman >/dev/null 2>&1; then
    pck_mngr="pacman"
fi

# ── helpers ──────────────────────────────────────────────────────────────────

# Collect apt package names that are not yet installed
apt_missing() {
    local missing=()
    for pkg in "$@"; do
        dpkg-query -W -f='${Status}' "$pkg" 2>/dev/null \
            | grep -q "install ok installed" || missing+=("$pkg")
    done
    echo "${missing[@]}"
}

# Collect pacman package names that are not yet installed
pacman_missing() {
    local missing=()
    for pkg in "$@"; do
        pacman -Q "$pkg" >/dev/null 2>&1 || missing+=("$pkg")
    done
    echo "${missing[@]}"
}

# Install a cargo crate only if the binary is not already present.
# Returns 0 if a fresh install occurred, 1 if already present.
# Usage: cargo_install <binary-name> [<crate-name>]
cargo_install() {
    if command -v "$1" >/dev/null 2>&1; then
        return 1
    fi
    cargo install "${2:-$1}"
}

# Prompt yes/no; returns 0 (true) if user answers y/Y
# Usage: prompt_yn "Question text"
prompt_yn() {
    local reply
    read -r -p "$1 [y/N] " reply
    [[ "$reply" =~ ^[Yy]$ ]]
}

# Build and install neovim stable from source
nvim_build_from_source() {
    (
        git clone https://github.com/neovim/neovim /tmp/neovim
        cd /tmp/neovim
        git checkout stable
        make -j"$(nproc)" CMAKE_BUILD_TYPE=Release
        sudo make install
    )
    rm -rf /tmp/neovim
}

# ── fish shell setup ──────────────────────────────────────────────────────────
if [ "$SHELL" = "/usr/bin/fish" ]; then
    if ! [ -f ~/.config/fish/functions/fisher.fish ] || ! command -v fisher >/dev/null 2>&1; then
        echo "fish shell found: Install fisher"
        fish -c "curl -sL https://git.io/fisher | source && fisher install jorgebucaran/fisher"
    fi
    if ! fish -c "type -q tide" >/dev/null 2>&1; then
        fish -c "fisher install IlanCosman/tide"
        fish -c "tide configure --auto --style=Lean --prompt_colors='True color' --show_time='No' --lean_prompt_height='Two lines' --prompt_connection=Disconnected --prompt_spacing=Sparse --icons='Few icons' --transient=No"
    fi
fi

# ── system packages ───────────────────────────────────────────────────────────
if [ "$pck_mngr" = "apt" ]; then
    read -ra missing <<< "$(apt_missing \
        ninja-build gettext libtool libtool-bin autoconf automake cmake g++ pkg-config \
        unzip curl bat fd-find ripgrep fzf httpie eza golang-go)"
    if [ ${#missing[@]} -gt 0 ] && [ -n "${missing[0]}" ]; then
        sudo apt install -y "${missing[@]}"
    fi
    [ -e /usr/bin/fd ]  || sudo ln -s /usr/bin/fdfind /usr/bin/fd
    [ -e /usr/bin/bat ] || sudo ln -s /usr/bin/batcat /usr/bin/bat
elif [ "$pck_mngr" = "pacman" ]; then
    read -ra missing <<< "$(pacman_missing \
        base-devel cmake unzip ninja curl bat exa fd ripgrep fzf sd httpie go)"
    if [ ${#missing[@]} -gt 0 ] && [ -n "${missing[0]}" ]; then
        sudo pacman -S --noconfirm "${missing[@]}"
    fi
fi

# ── nvm ───────────────────────────────────────────────────────────────────────
if [ ! -d "$HOME/.nvm" ]; then
    echo "Installing nvm"
    curl -o- https://raw.githubusercontent.com/nvm-sh/nvm/v0.40.3/install.sh | bash
fi
# Load nvm for the rest of this script
export NVM_DIR="$HOME/.nvm"
# shellcheck source=/dev/null
[ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"

# ── neovim ────────────────────────────────────────────────────────────────────
if ! command -v nvim >/dev/null 2>&1; then
    echo "Bootstrapping neovim from source"
    nvim_build_from_source
elif prompt_yn "Rebuild neovim from source to get the latest stable version?"; then
    nvim_build_from_source
fi

if command -v nvim >/dev/null 2>&1; then
    echo "Syncing nvim plugins"
    nvim --headless "+Lazy! sync" +qa
fi

# ── ov ────────────────────────────────────────────────────────────────────────
if ! command -v ov >/dev/null 2>&1; then
    echo "Bootstrapping ov"
    (
        git clone https://github.com/noborus/ov.git /tmp/ov
        cd /tmp/ov
        make install
    )
    rm -rf /tmp/ov
    command -v ov >/dev/null 2>&1 \
        && ov --completion fish > ~/.config/fish/completions/ov.fish
fi

# ── zoxide ────────────────────────────────────────────────────────────────────
if ! command -v zoxide >/dev/null 2>&1; then
    curl -sSfL https://raw.githubusercontent.com/ajeetdsouza/zoxide/main/install.sh | sh
fi

# ── rust + cargo tools ────────────────────────────────────────────────────────
if ! command -v rustup >/dev/null 2>&1; then
    curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh
else
    rustup update
fi

cargo_install tuicr
cargo_install tree-sitter tree-sitter-cli

# ── agent skills ─────────────────────────────────────────────────────────────
if prompt_yn "Install agent skills via npx skills?"; then
    export NODE_OPTIONS="--use-system-ca"

    # caveman family (source: JuliusBrussee/caveman)
    # includes: caveman, caveman-commit, caveman-compress, caveman-help,
    #           caveman-review, caveman-stats
    npx skills add -y JuliusBrussee/caveman

    # cavecrew + cavekit-* (source: JuliusBrussee/caveman-code)
    # includes: cavecrew, cavekit-design-system, cavekit-methodology,
    #           cavekit-revision, cavekit-validation-first
    npx skills add -y JuliusBrussee/caveman-code

    # brainstorm (source: obra/superpowers, skill: brainstorming)
    npx skills add -y obra/superpowers@brainstorming

    # grill-me / grilling (source: mattpocock/skills, skill: grilling)
    npx skills add -y mattpocock/skills@grilling
fi
